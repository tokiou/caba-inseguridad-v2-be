APP_ENV=development
HTTP_PORT=8080

# PostgreSQL + PostGIS
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=caba_routes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5434/caba_routes?sslmode=disable

ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org

LOG_LEVEL=info
LOG_FORMAT=text

# Auth — JWT access tokens + opaque refresh tokens
# JWT_SECRET is required outside development; the server refuses to start with an
# empty or placeholder secret when APP_ENV != development.
JWT_SECRET=change_me
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
# Set COOKIE_SECURE=true in production (HTTPS). SameSite: lax | strict | none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
